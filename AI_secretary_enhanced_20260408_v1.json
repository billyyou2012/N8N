      "id": "9234d1e6-0e88-4a35-81aa-85355dffdb6e",
      "name": "Execute NOCTT Query",
      "credentials": {
        "microsoftSql": {
          "id": "aRzYQ0Hf0qsCHiZX",
          "name": "Microsoft SQL account"
        }
