      "parameters": {
        "functionCode": "// 錯誤處理函數\nconst errorData = $input.item.json;\n\n// 記錄錯誤日誌\nconst errorLog = {\n  timestamp: new Date().toISOString(),\n  schedule_id: errorData.schedule_id,\n  error_type: errorData.error?.type || 'unknown',\n  error_message: errorData.error?.message || '未知錯誤',\n  stack_trace: errorData.error?.stack,\n  execution_context: errorData\n};\n\n// 構建錯誤訊息\nlet errorMessage = `❌ 任務執行失敗：${errorData.task_description || '未知任務'}\\n\\n` +\n  `⚠️ 錯誤原因：${errorData.error?.message || '未知錯誤'}\\n` +\n  `🔧 建議操作：請聯繫系統管理員或稍後重試\\n` +\n  `⏱️ 發生時間：${new Date().toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })}`;\n\nif (errorData.schedule_id) {\n  errorMessage += `\\n📋 任務ID：${errorData.schedule_id}`;\n}\n\nreturn [\n  {\n    json: {\n      ...errorData,\n      error_log: errorLog,\n      error_message_display: errorMessage,\n      final_status: \"failed\"\n    }\n  }\n];"
      },
