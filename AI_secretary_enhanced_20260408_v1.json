    {
      "parameters": {
        "functionCode": "// 執行查詢工單任務\nconst params = $input.item.json.execution_params;\n\n// 構建NOCTT查詢參數\nconst queryParams = JSON.parse(params.task_parameters || '{}');\n\n// 根據參數生成SQL查詢\nlet sqlQuery = \"SELECT TOP 100 * FROM NOC_TT_AI_3 WHERE 1=1\";\n\nif (queryParams.class_level) {\n  sqlQuery += ` AND Class_Level = '${queryParams.class_level.replace(/[';]/g, '')}'`;\n}\n\nif (queryParams.status) {\n  sqlQuery += ` AND Status = '${queryParams.status.replace(/[';]/g, '')}'`;\n}\n\nif (queryParams.date_range) {\n  const startDate = new Date();\n  startDate.setDate(startDate.getDate() - (queryParams.date_range.days || 7));\n  sqlQuery += ` AND Created_Date >= '${startDate.toISOString().split('T')[0]}'`;\n}\n\nsqlQuery += \" ORDER BY Created_Date DESC\";\n\nreturn [\n  {\n    json: {\n      ...$input.item.json,\n      sql_query: sqlQuery,\n      target_tool: \"NOCTT\",\n      execution_type: \"query_ticket\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1040,
        912
      ],
      "id": "b33548f5-f7bb-4f29-b240-5a47bfdc3eb4",
      "name": "Prepare Query Ticket"
    },
    {
      "parameters": {
        "functionCode": "// 執行提醒任務\nconst params = $input.item.json.execution_params;\n\n// 構建提醒訊息\nconst reminderMessage = `⏰ 提醒：${params.task_description}\\n\\n` +\n  `📅 預定時間：${new Date().toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })}\\n` +\n  `👤 建立者：${params.user_name}`;\n\nreturn [\n  {\n    json: {\n      ...$input.item.json,\n      reminder_message: reminderMessage,\n      execution_type: \"reminder\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1040,
        1104
      ],
      "id": "eec583d1-84a7-47fa-a94d-48ef2b5dfa71",
      "name": "Prepare Reminder"
    },
    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "當需要查詢 NOC_TT_AI_3 資料庫中的工單數據時，必須使用此工具。參數 query 請帶入純 SQL 語句。",
        "operation": "executeQuery",
