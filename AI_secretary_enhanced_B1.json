    {
      "parameters": {
        "functionCode": "// 準備排程執行參數\nconst schedule = $input.item.json;\n\n// 構建執行參數\nconst executionParams = {\n  schedule_id: schedule.id,\n  record_uuid: schedule.record_uuid,\n  task_type: schedule.task_type,\n  task_parameters: schedule.task_parameters,\n  task_description: schedule.task_description,\n  user_id: schedule.user_id,\n  user_name: schedule.user_name,\n  channel_id: schedule.channel_id || $env.TEAMS_DEFAULT_CHANNEL,\n  handler_agent: schedule.handler_agent || 'AI Agent2',\n  timeout_seconds: schedule.timeout_seconds || 300\n};\n\n// 更新狀態為 executing\nconst updateQuery = `EXEC sp_update_schedule_status \n  @schedule_id = ${schedule.id},\n  @new_status = 'executing'`;\n\nreturn [\n  {\n    json: {\n      ...schedule,\n      execution_params: executionParams,\n      update_query: updateQuery\n    }\n  }\n];"
      },
