    {
      "parameters": {
        "functionCode": "// 處理查詢結果\nconst queryResult = $input.item.json;\nconst scheduleData = $input.item.json[0]?.json?.scheduleData || $input.item.json;\n\n// 格式化結果\nlet formattedResult = \"查詢完成！\\\\n\\\\n\";\n\nif (queryResult && queryResult.length > 0) {\n  formattedResult += `📊 找到 ${queryResult.length} 筆記錄\\\\n\\\\n`;\n  \n  // 取前5筆顯示摘要\n  const sampleCount = Math.min(5, queryResult.length);\n  for (let i = 0; i < sampleCount; i++) {\n    const record = queryResult[i];\n    formattedResult += `${i+1}. ${record.Class_Level || 'N/A'} - ${record.Status || 'N/A'} - ${record.Created_Date || 'N/A'}\\n`;\n  }\n  \n  if (queryResult.length > sampleCount) {\n    formattedResult += `... 還有 ${queryResult.length - sampleCount} 筆記錄\\n`;\n  }\n} else {\n  formattedResult += \"📭 未找到符合條件的記錄\\n\";\n}\n\nreturn [\n  {\n    json: {\n      ...scheduleData,\n      query_result: queryResult,\n      formatted_result: formattedResult,\n      result_count: queryResult ? queryResult.length : 0,\n      execution_status: \"success\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        4432,
        -176
      ],
      "id": "ed7dc3b2-48d1-40c4-84a4-c2b34924f1d7",
      "name": "Format Query Result"
    },
    {
      "parameters": {
        "functionCode": "// 合併所有執行結果\nconst executionResult = $input.item.json;\n\n// 構建Teams訊息\nlet teamsMessage = \"\";\n\nif (executionResult.execution_type === \"query_ticket\") {\n  teamsMessage = `✅ 工單查詢完成：${executionResult.task_description}\\n\\n` +\n    executionResult.formatted_result +\n    `\\n⏱️ 執行時間：${new Date().toLocaleString('zh-TW', { timeZone: 'Asia/Taipei' })}`;\n} else if (executionResult.execution_type === \"reminder\") {\n  teamsMessage = executionResult.reminder_message;\n}\n\n// 添加任務ID\nif (executionResult.schedule_id) {\n  teamsMessage += `\\n📋 任務ID：${executionResult.schedule_id}`;\n}\n\nreturn [\n  {\n    json: {\n      ...executionResult,\n      teams_message: teamsMessage,\n      final_status: \"completed\"\n    }\n  }\n];"
      },
